# TenaOS-Backend (OpenMRS Ref-App 3 + MariaDB) — env file for the
# `TenaOS-Backend/docker-compose.yml` standalone dev stack.
#
# For the full TenaOS demo, use the repo-root `docker-compose.yml` +
# `demo.env.example` instead. This file is for backend-only iteration.

OPENMRS_PORT=18080
OPENMRS_DB_NAME=openmrs
OPENMRS_DB_USER=openmrs

# REQUIRED: rotate before any public exposure.
OPENMRS_DB_PASSWORD=CHANGE_ME
OPENMRS_ADMIN_PASSWORD=CHANGE_ME

# JVM memory cap.
OPENMRS_JAVA_MEMORY_OPTS=-Xmx1g

# Healthcheck identity. In production point this at the read-only
# healthcheck user provisioned via TenaOS-Backend/metadata/healthcheck-user.sql.
OPENMRS_HEALTHCHECK_USERNAME=admin
OPENMRS_HEALTHCHECK_PASSWORD=CHANGE_ME

# Public host the SPA / OpenMRS are served behind.
TENAOS_PUBLIC_HOST=localhost

# CORS origins allowed to call TenaAgent during local dev.
TENA_AGENT_CORS_ORIGINS=http://localhost:5173
