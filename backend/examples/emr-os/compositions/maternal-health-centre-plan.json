{
  "schemaVersion": "1.0",
  "planId": "maternal-health-centre",
  "baseConfig": {
    "archetype": "specialty-clinic",
    "facilityProfile": {
      "code": "hope-anc",
      "name": "Hope Maternal Health Centre",
      "facilityType": "specialty-clinic",
      "ownership": "private-not-for-profit",
      "country": "Uganda",
      "timezone": "Africa/Kampala",
      "languages": ["en", "lg"],
      "defaultCurrency": "UGX"
    },
    "locations": [
      {
        "id": "main-facility",
        "name": "Hope Maternal Health Centre",
        "kind": "facility",
        "facilityLocation": true,
        "address": {
          "cityVillage": "Mbarara",
          "country": "Uganda"
        }
      }
    ],
    "registrationModel": {
      "walkInAllowed": true,
      "appointmentMode": "hybrid",
      "identifierStrategy": {
        "identifierType": "OpenMRS ID",
        "baseCharacterSet": "0123456789",
        "firstIdentifierBase": "20001",
        "prefix": "ANC-",
        "minLength": 7,
        "maxLength": 12
      }
    },
    "labModel": {
      "enabled": true,
      "departmentLocationId": "lab:laboratory",
      "integratedOrdering": true,
      "specimenHandoffMode": "manual",
      "resultDeliveryMode": "fhir",
      "resultReviewerRoleIds": ["midwife"]
    },
    "identityModel": {
      "roles": [
        {
          "id": "admin",
          "name": "Admin",
          "openmrsRoles": ["Organizational: System Administrator"],
          "openelisRoles": ["admin"],
          "orthancPermissions": ["all"]
        },
        {
          "id": "midwife",
          "name": "Midwife",
          "openmrsRoles": ["Organizational: Doctor", "Provider"]
        },
        {
          "id": "lab-tech",
          "name": "Lab Technician",
          "keycloakRoles": ["lab-technician"],
          "openelisRoles": ["lab-technician"]
        }
      ],
      "users": [
        {
          "username": "hope.admin",
          "firstName": "Hope",
          "lastName": "Admin",
          "roleIds": ["admin"]
        },
        {
          "username": "midwife.1",
          "firstName": "Grace",
          "lastName": "Nakaweesi",
          "roleIds": ["midwife"]
        }
      ]
    },
    "governance": {
      "approvalRequired": true,
      "allowedRequestorRoleIds": ["admin"],
      "dryRunByDefault": true,
      "changeTicketPrefix": "ANC"
    }
  },
  "packSelections": [
    {
      "packId": "maternal-health",
      "namespace": "anc",
      "parentLocationId": "main-facility"
    },
    {
      "packId": "cashier-shared",
      "namespace": "cashier",
      "parentLocationId": "main-facility"
    },
    {
      "packId": "pharmacy-shared",
      "namespace": "pharmacy",
      "parentLocationId": "main-facility"
    },
    {
      "packId": "laboratory-shared",
      "namespace": "lab",
      "parentLocationId": "main-facility"
    }
  ],
  "crossPackRoutingRules": [
    {
      "id": "anc-to-cashier",
      "fromQueueId": "anc:anc-queue",
      "toQueueId": "cashier:cashier-queue",
      "mode": "conditional",
      "requiresPayment": true
    },
    {
      "id": "cashier-to-pharmacy",
      "fromQueueId": "cashier:cashier-queue",
      "toQueueId": "pharmacy:pharmacy-queue",
      "mode": "recommended"
    }
  ],
  "overlays": {
    "billingModel": {
      "pricingRules": [
        {
          "id": "anc-standard",
          "billableServiceId": "anc:anc-visit-service",
          "amount": 20000,
          "patientCategory": "standard",
          "requiresPaymentBeforeService": true
        }
      ]
    }
  }
}
