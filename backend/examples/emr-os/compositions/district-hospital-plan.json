{
  "schemaVersion": "1.0",
  "planId": "district-hospital",
  "baseConfig": {
    "archetype": "district-hospital",
    "facilityProfile": {
      "code": "district-hospital",
      "name": "River District Hospital",
      "facilityType": "district-hospital",
      "ownership": "public",
      "country": "Tanzania",
      "timezone": "Africa/Dar_es_Salaam",
      "languages": ["en", "sw"],
      "defaultCurrency": "TZS"
    },
    "locations": [
      {
        "id": "hospital-main",
        "name": "River District Hospital",
        "kind": "facility",
        "facilityLocation": true,
        "address": {
          "cityVillage": "Morogoro",
          "country": "Tanzania"
        }
      }
    ],
    "registrationModel": {
      "walkInAllowed": true,
      "appointmentMode": "hybrid",
      "identifierStrategy": {
        "identifierType": "OpenMRS ID",
        "baseCharacterSet": "0123456789",
        "firstIdentifierBase": "30001",
        "prefix": "RDH-",
        "minLength": 8,
        "maxLength": 12
      }
    },
    "labModel": {
      "enabled": true,
      "departmentLocationId": "lab:laboratory",
      "integratedOrdering": true,
      "specimenHandoffMode": "manual",
      "resultDeliveryMode": "fhir",
      "resultReviewerRoleIds": ["doctor"]
    },
    "imagingModel": {
      "enabled": true,
      "departmentLocationId": "imaging:radiology",
      "defaultViewer": "oe2",
      "studyShareEnabled": true,
      "rolePermissions": {
        "radiologist": ["view", "download", "send", "share", "upload", "modify", "api-view", "worklists"],
        "doctor": ["view", "download", "share", "api-view"]
      },
      "authorizedLabels": {
        "radiologist": ["*"],
        "doctor": ["*"]
      }
    },
    "identityModel": {
      "roles": [
        {
          "id": "admin",
          "name": "Admin",
          "openmrsRoles": ["Organizational: System Administrator"],
          "openelisRoles": ["admin"],
          "orthancPermissions": ["all"]
        },
        {
          "id": "doctor",
          "name": "Doctor",
          "keycloakRoles": ["doctor"],
          "openmrsRoles": ["Organizational: Doctor", "Provider"]
        },
        {
          "id": "radiologist",
          "name": "Radiologist",
          "keycloakRoles": ["radiologist"],
          "orthancPermissions": ["view", "download", "send", "share", "upload", "modify", "api-view", "worklists"]
        },
        {
          "id": "lab-tech",
          "name": "Lab Technician",
          "keycloakRoles": ["lab-technician"],
          "openelisRoles": ["lab-technician"]
        }
      ],
      "users": [
        {
          "username": "river.admin",
          "firstName": "River",
          "lastName": "Admin",
          "roleIds": ["admin"]
        },
        {
          "username": "dr.msuya",
          "firstName": "Asha",
          "lastName": "Msuya",
          "roleIds": ["doctor"]
        },
        {
          "username": "rad.moses",
          "firstName": "Moses",
          "lastName": "Mlama",
          "roleIds": ["radiologist"]
        }
      ]
    },
    "governance": {
      "approvalRequired": true,
      "allowedRequestorRoleIds": ["admin"],
      "dryRunByDefault": true,
      "changeTicketPrefix": "RDH"
    }
  },
  "packSelections": [
    {
      "packId": "opd-core",
      "namespace": "opd",
      "parentLocationId": "hospital-main"
    },
    {
      "packId": "cashier-shared",
      "namespace": "cashier",
      "parentLocationId": "hospital-main"
    },
    {
      "packId": "pharmacy-shared",
      "namespace": "pharmacy",
      "parentLocationId": "hospital-main"
    },
    {
      "packId": "laboratory-shared",
      "namespace": "lab",
      "parentLocationId": "hospital-main"
    },
    {
      "packId": "imaging-shared",
      "namespace": "imaging",
      "parentLocationId": "hospital-main"
    }
  ],
  "crossPackRoutingRules": [
    {
      "id": "consult-to-cashier",
      "fromQueueId": "opd:consult-queue",
      "toQueueId": "cashier:cashier-queue",
      "mode": "conditional",
      "requiresPayment": true
    },
    {
      "id": "consult-to-lab",
      "fromQueueId": "opd:consult-queue",
      "toQueueId": "lab:lab-queue",
      "mode": "conditional",
      "requiresPayment": true
    },
    {
      "id": "consult-to-imaging",
      "fromQueueId": "opd:consult-queue",
      "toQueueId": "imaging:imaging-queue",
      "mode": "conditional",
      "requiresPayment": true
    },
    {
      "id": "cashier-to-pharmacy",
      "fromQueueId": "cashier:cashier-queue",
      "toQueueId": "pharmacy:pharmacy-queue",
      "mode": "recommended"
    }
  ],
  "overlays": {
    "billingModel": {
      "pricingRules": [
        {
          "id": "consult-standard",
          "billableServiceId": "opd:consult-service",
          "amount": 7000,
          "patientCategory": "standard",
          "requiresPaymentBeforeService": true
        }
      ]
    },
    "stockPharmacyModel": {
      "rules": [
        {
          "id": "paracetamol-minimum",
          "stockItemName": "Paracetamol 500mg",
          "locationId": "pharmacy:pharmacy",
          "reorderLevel": 100
        }
      ]
    }
  }
}
