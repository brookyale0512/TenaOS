# TenaOS backend defaults.
#
# NOTE: env var prefix changed from CLINICDX_LITE_* to TENAOS_*.
# Existing deployments must update their .env file before redeploy.
# See /MIGRATION.md at the repo root for the full ClinicDx Lite -> TenaOS rename.
#
# Uses 18080 by default so it can run beside the legacy ClinicDx (MedGemma) stack.
OPENMRS_PORT=18080
OPENMRS_DB_NAME=openmrs
OPENMRS_DB_USER=openmrs
# REQUIRED: Set a strong, unique database password before any public exposure.
OPENMRS_DB_PASSWORD=CHANGE_ME

# Admin password is required for the OpenMRS bootstrap.
# REQUIRED: Rotate this before any external exposure — never leave the default.
OPENMRS_ADMIN_PASSWORD=CHANGE_ME

# JVM memory cap. Increase for production loads; the default fits the
# reference application demo profile.
OPENMRS_JAVA_MEMORY_OPTS=-Xmx1g

# Healthcheck identity. In production set these to the dedicated read-only
# healthcheck user provisioned via backend/metadata/healthcheck-user.sql
# so the container probe never relies on admin credentials.
OPENMRS_HEALTHCHECK_USERNAME=admin
OPENMRS_HEALTHCHECK_PASSWORD=CHANGE_ME

# Public host the SPA / OpenMRS are served behind. Used by scripts to compute
# OPENMRS_PUBLIC_URL. (Was CLINICDX_LITE_PUBLIC_HOST in pre-rename deployments.)
TENAOS_PUBLIC_HOST=localhost

# vLLM / Gemma-4 endpoint. Point this at your inference server.
VLLM_BASE_URL=http://YOUR_VLLM_HOST:8000/v1
VLLM_MODEL=gemma-4

# CDS service CORS.
# Set to the public URL of the frontend in production
# (e.g. https://tenaos.example.org). Multiple origins are comma-separated.
CDS_CORS_ORIGINS=http://localhost:5173
