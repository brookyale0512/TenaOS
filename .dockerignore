# Build-context allowlist for every Dockerfile in this repo. Keeps images
# small and prevents secrets / dumps / runtime data from being baked in.

# Frontend artifacts.
TenaOS-Frontend/node_modules/
TenaOS-Frontend/dist/
TenaOS-Frontend/dist-ssr/
TenaOS-Frontend/coverage/
TenaOS-Frontend/playwright-report/
TenaOS-Frontend/test-results/
TenaOS-Frontend/.env
TenaOS-Frontend/.env.*
!TenaOS-Frontend/.env.example

# Backend image build artifacts.
TenaOS-Backend/build-cache/

# Runtime / clinical data must NEVER enter any image.
runtime-artifacts/
TenaAgent/runtime/
**/*.sql
**/*.sql.gz
**/*.dump
**/*.bak
**/*.sqlite
**/*.sqlite3

# Model weights are bind-mounted at runtime, not baked into images.
models/*.gguf
models/*.litertlm
models/*.safetensors

# fetch-models.sh output — must never enter the build context.
tenaos-bootstrap/
qdrant-snapshots/
embedgemma-300m/
*.snapshot
*.snapshot.checksum

# VCS and editor noise.
.git/
.github/
.idea/
.vscode/
.pytest_cache/
__pycache__/
*.py[cod]

# Secrets.
*-key.json
*service-account*.json
.env
.env.*
!.env.example
