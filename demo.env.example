# TenaOS demo configuration — copy to `.env` and edit before:
#   docker compose up -d

# ── Public hostname (used by OpenMRS for absolute URLs) ─────────────────
TENAOS_PUBLIC_HOST=localhost

# ── Host port (the SPA, OpenMRS, and TenaAgent are all reachable here) ──
TENAOS_HOST_PORT=8080

# ── Required secrets ────────────────────────────────────────────────────
# Demo credentials. Rotate before any real deployment.
OPENMRS_DB_PASSWORD=Admin123
OPENMRS_ADMIN_PASSWORD=Admin123
OPENMRS_HEALTHCHECK_USERNAME=admin
OPENMRS_HEALTHCHECK_PASSWORD=Admin123
OPENMRS_SERVICE_USER=admin
OPENMRS_SERVICE_PASSWORD=Admin123
OPENMRS_JAVA_MEMORY_OPTS=-Xmx4g

# Seed 50 synthetic patients, visits, vitals, and notes on first boot.
TENAOS_SEED_DEMO_PATIENTS=true
TENAOS_DEMO_PATIENT_COUNT=50

# ── Bind-mounted artifact paths (REQUIRED) ──────────────────────────────
# Easiest way to populate these: run `bash scripts/fetch-models.sh`
# which downloads everything from HuggingFace and prints the exact
# values to paste here.
#
# Layout the fetcher produces (defaults to ./tenaos-bootstrap/):
#   <bootstrap>/models/                   Gemma 4 BF16 GGUF + mmproj
#   <bootstrap>/embedgemma-300m/          EmbedGemma 300M weights
#   <bootstrap>/ciel/ciel_search.sqlite3  CIEL terminology SQLite
#   <bootstrap>/qdrant-snapshots/         Pre-built Qdrant collections
#
TENAOS_MODELS_PATH=./models
TENAOS_EMBED_MODEL_PATH=/path/to/embedgemma-300m
TENAOS_CIEL_SQLITE_PATH=/path/to/ciel_search.sqlite3
TENAOS_QDRANT_SNAPSHOTS_PATH=/path/to/qdrant-snapshots
