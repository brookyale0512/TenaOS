# TenaOS demo configuration — copy to `.env` and edit before:
#   docker compose up -d

# ── Public hostname (used by OpenMRS for absolute URLs) ─────────────────
TENAOS_PUBLIC_HOST=localhost

# ── Host port (the SPA, OpenMRS, and TenaAgent are all reachable here) ──
TENAOS_HOST_PORT=8080

# ── Required secrets ────────────────────────────────────────────────────
# REQUIRED: rotate before any deployment. The image refuses to start
# unless OPENMRS_DB_PASSWORD and OPENMRS_ADMIN_PASSWORD are set.
OPENMRS_DB_PASSWORD=CHANGE_ME
OPENMRS_ADMIN_PASSWORD=CHANGE_ME
OPENMRS_HEALTHCHECK_USERNAME=admin
OPENMRS_HEALTHCHECK_PASSWORD=CHANGE_ME
OPENMRS_SERVICE_USER=admin
OPENMRS_SERVICE_PASSWORD=CHANGE_ME
OPENMRS_JAVA_MEMORY_OPTS=-Xmx1g

# ── Required host paths for bind-mounted model artifacts ────────────────
# Future releases will fetch these automatically (scripts/fetch-models.sh).
# For now, point at your local copies:
TENAOS_EMBED_MODEL_PATH=/path/to/embedgemma-300m
TENAOS_CIEL_SQLITE_PATH=/path/to/ciel_search.sqlite3
# The Gemma 4 BF16 GGUF + mmproj live in ./models/ and are bind-mounted automatically.
