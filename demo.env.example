# TenaOS demo configuration — copy to `.env` and edit before:
#   docker compose up -d

# ── Public hostname (used by OpenMRS for absolute URLs) ─────────────────
TENAOS_PUBLIC_HOST=localhost

# ── Host port (the SPA, OpenMRS, and TenaAgent are all reachable here) ──
TENAOS_HOST_PORT=8080

# ── Required secrets (rotate before any public deployment) ──────────────
OPENMRS_DB_PASSWORD=change-this-db-password
OPENMRS_ADMIN_PASSWORD=change-this-admin-password
OPENMRS_HEALTHCHECK_USERNAME=admin
OPENMRS_HEALTHCHECK_PASSWORD=change-this-admin-password
OPENMRS_SERVICE_USER=admin
OPENMRS_SERVICE_PASSWORD=change-this-admin-password
OPENMRS_JAVA_MEMORY_OPTS=-Xmx1g

# ── Required host paths for bind-mounted model artifacts ────────────────
# Future releases will fetch these automatically (see scripts/fetch-models.sh).
# For now, point at your existing local copies:
TENAOS_EMBED_MODEL_PATH=/home/RAZERBLADE/who_cds_pipeline/models/embedgemma-300m
TENAOS_CIEL_SQLITE_PATH=/var/www/ClinicDx_backend/CIEL/ciel_search.sqlite3
# The Gemma 4 BF16 GGUF + mmproj live in ./models/ and are bind-mounted automatically.
