{
  "schemaVersion": 1,
  "notes": [
    "Benchmark prompts derived from cloned open-source AMPATH/OpenMRS forms in /var/www/forms.",
    "Gold concepts use CIEL numeric IDs extracted from padded OpenMRS UUIDs in the source schemas.",
    "These prompts are intentionally separate from prompts.json so the original challenge eval remains stable."
  ],
  "prompts": [
    {
      "id": "corpus-ampath-demo-triage",
      "sourceForm": "/var/www/forms/AMPATH-openmrs-angularFormentry/app/scripts/formentry/schema/demo-triage.json",
      "request": "Create a triage vital signs form for an outpatient clinic with systolic and diastolic blood pressure, pulse rate, temperature in Celsius, weight in kilograms, height in centimeters, and oxygen saturation.",
      "encounterType": "Consultation",
      "minQuestions": 6,
      "maxQuestions": 10,
      "requireAnyOf": [
        {"label": "systolic blood pressure", "conceptIds": ["5085"]},
        {"label": "diastolic blood pressure", "conceptIds": ["5086"]},
        {"label": "pulse or heart rate", "conceptIds": ["5087"]},
        {"label": "temperature", "conceptIds": ["5088"]},
        {"label": "weight", "conceptIds": ["5089"]},
        {"label": "height", "conceptIds": ["5090"]},
        {"label": "oxygen saturation", "conceptIds": ["5092"]}
      ],
      "forbiddenClasses": ["Drug", "Diagnosis"]
    },
    {
      "id": "corpus-openmrs-tb-enrollment",
      "sourceForm": "/var/www/forms/openmrs-openmrs-form-engine-lib/__mocks__/forms/rfe-forms/post-submission-test-form.json",
      "request": "Create a TB care enrollment form for a clinic to record the TB program type, the date the patient was enrolled in tuberculosis care, and the DS TB treatment number.",
      "encounterType": "Consultation",
      "minQuestions": 3,
      "maxQuestions": 8,
      "requireAnyOf": [
        {"label": "TB program type", "conceptIds": ["163775", "164411"]},
        {"label": "date enrolled in TB care", "conceptIds": ["161552"]},
        {"label": "DS TB treatment number", "conceptIds": ["161654"]}
      ],
      "forbiddenClasses": ["Drug", "Diagnosis"]
    },
    {
      "id": "corpus-openmrs-hiv-service-enrollment",
      "sourceForm": "/var/www/forms/openmrs-openmrs-form-engine-lib/__mocks__/forms/rfe-forms/test-enrolment-form.json",
      "request": "Create an HIV care service enrollment form to record the date enrolled in HIV care, the patient's unique service identifier, population category, and general patient notes.",
      "encounterType": "Consultation",
      "minQuestions": 4,
      "maxQuestions": 10,
      "requireAnyOf": [
        {"label": "enrollment date", "conceptIds": ["160555"]},
        {"label": "unique ID", "conceptIds": ["162576"]},
        {"label": "population category", "conceptIds": ["166432"]},
        {"label": "general notes", "conceptIds": ["165095"]}
      ],
      "forbiddenClasses": ["Drug", "Diagnosis"]
    }
  ]
}
