{
  "schemaVersion": 1,
  "notes": [
    "Each prompt is a free-text form-build request that a non-technical clinician might type.",
    "`encounterType` is the OpenMRS encounter-type display name the operator picks during Stage 1.",
    "`goldConcepts` is the SME-graded set of CIEL numeric ids that a correct draft must include at least one of per `requireAnyOf` group.",
    "`forbiddenClasses` is a soft check; a draft that adds Drug/Diagnosis fields is graded down.",
    "`minQuestions` / `maxQuestions` bound the basket size (5-18 covers the realistic clinical range).",
    "Gold concepts are intentionally a UNION across plausible CIEL matches because CIEL has many synonyms; the agent only needs to pick one of each cluster."
  ],
  "prompts": [
    {
      "id": "anc-intake",
      "request": "Build me an ANC intake form for a first antenatal visit",
      "encounterType": "Consultation",
      "minQuestions": 6,
      "maxQuestions": 18,
      "requireAnyOf": [
        {"label": "chief complaint or symptoms", "conceptIds": ["5219", "1390", "160531"]},
        {"label": "gravidity / parity", "conceptIds": ["5624", "1053", "1054", "5630"]},
        {"label": "last menstrual period", "conceptIds": ["1427", "1465"]},
        {"label": "HIV status or test", "conceptIds": ["1063", "1169"]}
      ],
      "forbiddenClasses": ["Drug", "Diagnosis"]
    },
    {
      "id": "tb-initial",
      "request": "Create a TB initial assessment form for an adult patient",
      "encounterType": "Consultation",
      "minQuestions": 5,
      "maxQuestions": 18,
      "requireAnyOf": [
        {"label": "cough", "conceptIds": ["143264", "159666"]},
        {"label": "fever", "conceptIds": ["140238", "162628"]},
        {"label": "weight loss", "conceptIds": ["832", "1731"]},
        {"label": "TB exposure history", "conceptIds": ["1396", "159922", "160239", "165918"]}
      ],
      "forbiddenClasses": ["Drug", "Diagnosis"]
    },
    {
      "id": "hiv-initial",
