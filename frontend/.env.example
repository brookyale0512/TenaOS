VITE_OPENMRS_URL=/openmrs
VITE_ENABLE_EXTERNAL_MODULES=false
VITE_ENABLE_QUEUES=false
VITE_ENABLE_APPOINTMENTS=false
VITE_PATIENT_LIST_QUERY=
VITE_ACTIVE_VISIT_MAX_AGE_HOURS=24
VITE_VITALS_ENCOUNTER_TYPE_UUID=67a71486-1a54-468f-ac3e-7091a9a79584
VITE_CLINICAL_NOTE_ENCOUNTER_TYPE_UUID=d7151f82-c1f3-4152-a605-2f9ea7414a79
# CIEL concept for free-text clinical note (matches required-openmrs-metadata.json).
VITE_CLINICAL_NOTE_CONCEPT_UUID=162169AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_MEDICATION_ORDER_TYPE_UUID=131168f4-15f5-102d-96e4-000c29c2a5d7
VITE_LAB_ORDER_TYPE_UUID=52a447d3-a64a-11e3-9aeb-50e549534c5e
VITE_OUTPATIENT_CARE_SETTING_UUID=6f0c9a92-6f24-11e3-af88-005056821db0
VITE_DEFAULT_ORDERER_PROVIDER_UUID=
# Pre-selects a Visit Type in the StartVisitDialog. Leave blank to fall back to
# the only visit type returned by /visittype, or the first non-retired entry.
VITE_DEFAULT_VISIT_TYPE_UUID=
# Tag used to filter the Sidebar location selector and Start Visit picker.
# Defaults to "Login Location" — the OpenMRS 3 reference-app convention.
VITE_LOGIN_LOCATION_TAG=Login Location
VITE_PHONE_ATTR_TYPE_UUID=
VITE_VITAL_TEMPERATURE_CONCEPT_UUID=5088AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_VITAL_SYSTOLIC_BP_CONCEPT_UUID=5085AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_VITAL_DIASTOLIC_BP_CONCEPT_UUID=5086AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_VITAL_PULSE_CONCEPT_UUID=5087AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_VITAL_OXYGEN_SAT_CONCEPT_UUID=5092AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_VITAL_RESP_RATE_CONCEPT_UUID=5242AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_VITAL_HEIGHT_CONCEPT_UUID=5090AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_VITAL_WEIGHT_CONCEPT_UUID=5089AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# --- Dev proxy (vite dev server only — ignored in production builds) ---
# OpenMRS upstream the dev server proxies to.
OPENMRS_PROXY_TARGET=http://localhost:18080
# Set to "true" to inject Basic admin auth into every dev-proxy request, only
# useful when working against an OpenMRS that has no UI for sign-in. Production
# builds NEVER inject this header — nginx's same-origin proxy passes through
# the session cookie set by the in-app login page instead.
OPENMRS_DEV_INJECT_BASIC=false
# NEVER commit real credentials. Replace these only in your local .env file
# which is excluded from version control by .gitignore.
OPENMRS_DEV_USERNAME=admin
OPENMRS_DEV_PASSWORD=CHANGE_ME
